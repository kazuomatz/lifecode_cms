<div class="row">
  <% if flash[:alert] %>
  <div class="col-sm-8">
    <div class="alert alert-danger"><%=flash[:alert]%></div>
  </div>
  <%end%>
  <div class="col-sm-8">
    <div class="form-group">
      <label for="user_name">グループ名<span class="label_required">必須</span></label>
      <div class="input-group mb-3">
        <div class="input-group-prepend">
          <span class="input-group-text"><i class="fas fa-user-circle"></i></span>
        </div>
        <%= form.text_field :name, class: 'form-control',
                            data: {
                                parsley_required: true,
                                parsley_required_message: 'グループ名を入力して下さい。',
                            }
        %>
      </div>
    </div>

    <div class="form-group">
      <label for="user_name">説明</label>
      <div class="input-group mb-3">
        <div class="input-group-prepend">
          <span class="input-group-text"><i class="fas fa-user-circle"></i></span>
        </div>
        <%= form.text_area :description, class: 'form-control'%>
      </div>
    </div>
  </div>
</div>


<%- content_for :add_js do %>
  <script>
      $(function () {
          var form = new FormManager({img_noimage: '<%= asset_path('noimage.jpg') %>'});
          form.init();
      });
  </script>
<%- end %>