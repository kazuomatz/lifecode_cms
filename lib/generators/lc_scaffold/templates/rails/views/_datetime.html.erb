<%- if column[:show_time] -%>
<div class="col-sm-12">
  <div class="row">
    <div class="col-sm-<$$= column[:column] $$>">
      <div class="form-group">
        <label for="<%= column[:name] %>"><$$= column[:label] $$><$$= raw <%= model.name%>.required?(column[:name]) ? '<span class="label_required">' +  Settings.form.label.required + '</span>' : '' $$></label>
        <div class="input-group mb-3">
          <div class="input-group-prepend">
            <span class="input-group-text"><i class="far fa-calendar-alt"></i></span>
          </div>
          <$$= form.text_field  <%= ':' + column[:name] %>,
                              class: 'form-control _input-date',
                              value: <%= var_model %>.<%= column[:name] %>.present? ? <%= var_model %>.<%= column[:name] %>.strftime('%Y/%m/%d') : '',
                              data: <%= model.name %>.parsley_data(column[:name]) $$>
        </div>
      </div>
    </div>
    <div class="col-sm-3">
      <div class="form-group">
        <label for="<%= column[:name] %>">　</label>
        <div class="input-group mb-3">
          <div class="input-group-prepend">
            <span class="input-group-text"><i class="far fa-clock"></i></span>
          </div>
          <$$= form.text_field  <%= ':' + column[:name] %>_time,
                                class: 'form-control _input-time',
                                value: <%= var_model %>.<%= column[:name] %>.present? ? <%= var_model %>.<%= column[:name] %>.strftime('%H:%M') : '',
                                data: <%= model.name %>.parsley_data(column[:name]) $$>
        </div>
      </div>
    </div>
  </div>
</div>
<%-else %>
<div class="col-sm-<$$= column[:column] $$>">
  <div class="form-group">
    <label for="<%= column[:name] %>"><$$= column[:label] $$><$$= raw <%= model.name%>.required?(column[:name]) ? '<span class="label_required">' +  Settings.form.label.required + '</span>' : '' $$></label>
    <div class="input-group mb-3">
      <div class="input-group-prepend">
        <span class="input-group-text"><i class="far fa-calendar-alt"></i></span>
      </div>
      <$$= form.text_field  <%= ':' + column[:name] %>,
      class: 'form-control _input-date',
      value: <%= var_model %>.<%= column[:name] %>.present? ? <%= var_model %>.<%= column[:name] %>.strftime('%Y/%m/%d') : '',
      data: <%= model.name %>.parsley_data(column[:name]) $$>
    </div>
  </div>
</div>
<%- end -%>