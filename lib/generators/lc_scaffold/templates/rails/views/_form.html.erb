<%#- encoding: UTF-8 -%>
<!---
#  _form.erb
#  Generated by LifeCodeCMS Scaffold Generator
-->
<div class="row">
  <%%- if flash[:alert] -%>
  <div class="col-sm-8">
    <div class="alert alert-danger"><%%= flash[:alert] %></div>
  </div>
  <%%- end -%>
  <$$- columns = <%= model_name %>.form_attributes -$$>
  <%- model.form_attributes.each_with_index do |column, index| -%>
  <!---  <%= column[:name] %> : Generated by LifeCodeCMS Scaffold Generator  -->
  <$$- column = columns[<%= index %>] $$>
  <$$- validation_data = column[:validate] -$$>
  <%- if column[:name].index('prefecture_code').present? -%>
  <%= ApplicationController::render partial: 'rails/views/prefecture', locals:{column: column, model: model,var_model: var_model} -%>
  <%- elsif column[:name].index('prefecture_name').present? -%>
  <$$= form.hidden_field :<%= column[:name]%> $$>
  <%- elsif column[:name].index('city_code').present? -%>
  <%= ApplicationController::render partial: 'rails/views/city', locals:{column: column, model: model,var_model: var_model} -%>
  <%- elsif column[:name].index('city_name').present? -%>
  <$$= form.hidden_field :<%= column[:name]%> $$>
  <%- elsif column[:options].present? && column[:options].length  > 0 -%>
  <%= ApplicationController::render partial: 'rails/views/radio', locals:{ column: column, model: model,var_model: var_model } -%>
  <%- elsif column[:type] == :integer || column[:type] == :string -%>
  <%= ApplicationController::render partial: 'rails/views/text_field', locals:{column: column, model: model} -%>
  <%- elsif column[:type] == :attachment -%>
  <%- if column[:content_type].index('image') -%>
  <%= ApplicationController::render partial: 'rails/views/image_attachment', locals:{column: column, model_name: model_name} -%>
  <%- end %>
  <%- elsif column[:type] == :text -%>
  <%= ApplicationController::render partial: 'rails/views/text_area', locals:{column: column, model: model} -%>
  <%- elsif column[:type] == :datetime || column[:type] == :timestamp  -%>
  <%= ApplicationController::render partial: 'rails/views/datetime', locals:{column: column, model: model, var_model: var_model} -%>
  <%- end -%>
<%- end -%>
</div>

<%%- content_for :add_js do %>
<script>
  $(function () {
    new FormManager().init();
  });
</script>
<%%- end %>