<%#- encoding: UTF-8 -%>
<!---
#  _form.html.erb
#  Generated by LifeCodeCMS Scaffold Generator
-->
<div class="row">
  <%%- if flash[:alert] -%>
  <div class="col-sm-8">
    <div class="alert alert-danger"><%%= flash[:alert] %></div>
  </div>
  <%%- end -%>
  <%- model_name = @file_name.singularize.camelize
      model = class_eval model_name
      model.form_attributes.each do |column| -%>
  <!---  <%= column[:name] %> : Generated by LifeCodeCMS Scaffold Generator  -->
  <%- if column[:type] == :integer || column[:type] == :string -%>
  <div class="col-sm-<%= column[:column] %>">
    <div class="form-group">
      <label for="<%= column[:name] %>"><%= column[:label] %><%= model.required?(column[:name]) ? '<span class="label_required">' +  Settings.form.label.required + '</span>' : '' %></label>
        <div class="input-group mb-3">
        <%- if column[:icon].present? -%>
          <div class="input-group-prepend">
            <span class="input-group-text"><i class="<%= column[:icon] %>"></i></span>
          </div>
        <%- end -%>
        <%%= form.text_field <%= ':' + column[:name] %>, class: 'form-control', data: <%= model.validate_data(column[:name]).to_json(symbolize_names: true) %> %>
      </div>
    </div>
  </div>
  <%- elsif column[:type] == :attachment %>
  <%- if column[:content_type].index('image') -%>
    <div class="col-sm-<%= column[:column] %> container-fileinput">
      <div class="form-group">
        <label for="image"><%= column[:label] %></label>
        <div class="input-group">
          <div class="row">
            <div class="col-sm-12">
              <div class="image-preview">
                <%% if <%= model_name.underscore %>.<%= column[:name] %>.attached? %>
                <%%= image_tag <%= model_name.underscore %>.<%= column[:name] %>.variant(resize:'600x300').processed, class:'img-fluid' %>
                <%% else %>
                <%%= image_tag asset_path('noimage.jpg') %>
                <%% end %>
              </div>
            </div>
            <div class="col-sm-12">
              <label class="wrap-file-button mt-2">
                <span class="btn btn-primary">
                  <i class="fas fa-file"></i>
                  ファイル選択(jpg)
                  <%%= form.file_field :<%= column[:name] %>, class:'_image', style: 'display:none', accept: '<%=  column[:content_type]  %>'%>
                </span>
              </label>
            </div>
          </div>
        </div>
      </div>
    </div>
  <%- end %>
  <%- end -%>
  <%- end -%>
</div>
<%%- content_for :add_js do %>
 <script>
  $(function () {
    new FormManager().init();
  });
 </script>
<%%- end %>