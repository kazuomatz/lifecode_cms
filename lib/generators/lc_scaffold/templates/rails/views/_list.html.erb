<%#- encoding: UTF-8 -%>
<!---
#  _list.html.erb
#  Generated by LifeCodeCMS Scaffold Generator
-->
<%-
  model_name = @file_name.singularize.camelize
  model = class_eval model_name
  model_singularize = @file_name.singularize.underscore
  model_pluralize = @file_name.pluralize.underscore
-%>
<table class="table table-responsive-sm list-table">
  <thead>
    <tr>
      <%- model.list_columns.each do | name | -%>
      <%- if name == :id -%>
      <th width="120">ID</th>
      <%-else -%>
      <%- column = model.form_column(name) -%>
      <th><%= column.present? ?  column[:label] : name -%></th>
      <%- end -%>
      <%- end -%>
      <th class="operator-column"><%= Settings.form.label.operate -%></th>
  </thead>
  <tbody>
  <%%- <%= model_pluralize %>.each do |<%= model_singularize %>| -%>
    <tr>
    <%- model.list_columns.each do | name | -%>
      <td><%%= <%= model_singularize %>.<%= name %> %></td>
    <%- end -%>
      <td class="operator-column">
        <a class="btn-primary btn edit-btn" href="<%%= edit_admin_<%= model_singularize %>_path(<%= model_singularize %>,search_params)%>"><i class="far fa-edit"></i> <%= Settings.form.label.edit -%></a>
        <button type="button" class="btn-danger btn delete-btn" data-id="<%%= <%= model_singularize %>.id %>" data-name="<%%= <%= model_singularize %>.name %>" data-page="<%%= params[:page] || 1  %>"><i class="fas fa-trash"></i>  <%= Settings.form.label.destroy -%></button>
      </td>
    </tr>
  <%%- end -%>
  </tbody>
</table>