<div class="col-sm-8">
  <div id="map-<%= column[:name] %>" class="map"></div>
  <div class="mt-2 text-right"><button type="button" class="address-btn btn btn-primary"><i class="fas fa-map-marker-alt"></i> <$$= Settings.form.label.get_geom $$></button></div>
  </div>
  <div class="col-sm-4">
  <div class="form-group">
    <label for="<%= column[:name] %>_lat"><$$= Settings.form.label.latitude $$></label>
    <div class="input-group mb-3">
      <span class="input-group-text"><i class="fas fa-map-marker-alt"></i></span>
      <input type="text" id="admin_<%= var_model %>_<%= column[:name] %>_lat" name="<%= column[:name] %>_lat" class="form-control _lat_lon" value="<$$= <%= var_model %>.<%= column[:name] %>.nil?  ? -1 : <%= var_model %>.<%= column[:name] %>.y $$>" />
    </div>
  </div>
  <div class="form-group">
    <label for="<%= column[:name] %>_lng"><$$= Settings.form.label.longitude $$></label>
    <div class="input-group mb-3">
      <span class="input-group-text"><i class="fas fa-map-marker-alt"></i></span>
      <input type="text" id="admin_<%= var_model %>_<%= column[:name] %>_lng" name="<%= column[:name] %>_lng" class="form-control _lat_lon" value="<$$= <%= var_model %>.<%= column[:name] %>.nil?  ? -1 : <%= var_model %>.<%= column[:name] %>.x $$>" />
    </div>
  </div>
  <div class="form-group">
    <div class="input-group mb-3">
      <div class="map-edit-buttons">
        <button type="button" class="btn btn-default revert-btn" disabled>
          <i class="fas fa-redo"></i> <$$= Settings.form.label.undo $$>
        </button>
      </div>
    </div>
  </div>
  <$$= form.hidden_field <%= ':' + column[:name] %>, value: Point.to_s(<%= var_model %>.<%= column[:name] %>), class: '_spatial' $$>
</div>