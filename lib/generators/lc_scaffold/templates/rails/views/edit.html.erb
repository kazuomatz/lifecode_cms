<%-
  model_name = @file_name.singularize.camelize
  model = class_eval model_name
  model_pluralize = @file_name.pluralize.underscore
  model_singularize = @file_name.singularize.underscore
  form_attributes = model.form_attributes
-%>
<%%= content_for :breadcrumb do %>
  <%% items = [
      {url: '/', title: Settings.form.label.home},
      {url: "#{admin_<%= model_pluralize %>_path}", title: "<%= model.label %><%= Settings.form.label.list %>"},
      {title: "<%= model.label %><%= Settings.form.label.edit %>"},
  ]
  %>
  <%%= render partial: 'layouts/breadcrumb', locals: {items: items} %>
<%% end %>

<div class="container-fluid base">
  <div>
    <%%= form_for @<%= model_singularize %>, html: {class: 'form'} do |form| %>
      <div class="row">
        <div class="col-sm-12">
          <h1 class="func-title"><%= model.label %><%= Settings.form.label.edit %></h1>
          <div class="card">
            <div class="card-header">
              <strong><i class="fas fa-user-plus"></i>　<%= model.label %><%= Settings.form.label.edit %></strong>
            </div>
            <div class="card-body">
              <div class="row">
                <div class="col-sm-12">
                  <%%= render partial: 'form', locals: {form: form, <%= model_singularize %>: @<%= model_singularize %>} %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="regist-buttons-wrapper">
        <div class="card-footer regist-buttons">
          <button type="submit" class="btn btn-primary btn-lg">
            <i class="far fa-check-circle"></i> <%%= @<%= model_singularize %>.new_record? ? '<%= Settings.form.label.create %>' : '<%= Settings.form.label.update %>' %>
          </button>
          <a href="<%%= (session[params[:controller]].present? && session[params[:controller]]['return_path']) || admin_<%= model_pluralize %>_path %>" class="btn  btn-lg btn-default">
            <%= Settings.form.label.cancel %>
          </a>
        </div>
      </div>
    <%% end %>
  </div>
</div>

