<%% end %>
<%%= render partial: 'base/search_script', locals: {page: params[:landing_page] || 1}  %>
<div class="container-fluid base">
  <div>
    <div class="row">
      <div class="col-sm-12 ">
        <h1 class="func-title"><%= model.label %><%= Settings.form.label.manage %></h1>
        <%%= render partial: 'admin/<%= model_pluralize %>/search_box'%>
        <div class="card">
          <div class="card-header">
            <strong><i class="fas fa-user"></i>　<%= model.label %><%= Settings.form.label.list %></strong>
            <div class="right-button-element">
              <a class="btn-primary btn" href="<%%= new_admin_<%= model_singularize%>_path %>"><i class="fas fa-user-plus"></i> <%= model.label %><%= Settings.form.label.add %></a>
            </div>
          </div>
          <div class="card-body">
            <div class="row mt-10">
              <div class="col-sm-12">
                <div id="content-body"></div>
                <div id="pagination" class="clear"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
